{
  "name": "elefante-mcp",
  "version": "0.1.8",
  "mcpName": "io.github.amenophis1er/elefante",
  "description": "The open, Git-native memory protocol for MCP agents",
  "type": "module",
  "bin": {
    "elefante": "./dist/cli.js",
    "elefante-mcp": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:dashboard": "vite build",
    "dev": "concurrently -n api,vite -c blue,green \"node dist/cli.js serve --no-open --dev -p 3333\" \"vite\"",
    "dev:ts": "tsc --watch",
    "start": "node dist/cli.js",
    "mcp": "node dist/cli.js mcp",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run build:dashboard"
  },
  "keywords": [
    "ai-memory",
    "mcp",
    "git",
    "ai-agents",
    "claude",
    "codex",
    "memory-protocol",
    "model-context-protocol"
  ],
  "author": "Amen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amenophis1er/elefante.git"
  },
  "homepage": "https://github.com/amenophis1er/elefante#readme",
  "bugs": {
    "url": "https://github.com/amenophis1er/elefante/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@tanstack/react-virtual": "^3.13.24",
    "commander": "^13.1.0",
    "dompurify": "^3.4.0",
    "gray-matter": "^4.0.3",
    "nanoid": "^5.1.5",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "marked": "^18.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
